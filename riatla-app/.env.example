# Configuración de Riatla App

# Puerto WebSocket del daemon
WEBSOCKET_PORT=8765
WEBSOCKET_HOST=localhost

# Resolución (1920x1080 por defecto)
# Puedes cambiar en electron-main.js
WINDOW_WIDTH=1920
WINDOW_HEIGHT=1080

# Activar fullscreen (true/false)
FULLSCREEN=false

# Activar kiosk mode (no cierre con alt+f4)
KIOSK_MODE=false

# DevTools (development)
SHOW_DEV_TOOLS=false
